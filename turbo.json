{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "CODETHING_LOG_WS_EVENTS",
    "CODETHING_MODE",
    "CODETHING_PORT",
    "CODETHING_NO_BROWSER",
    "CODETHING_STATE_DIR",
    "CODETHING_AUTH_TOKEN",
    "CODETHING_DESKTOP_WS_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@acme/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
