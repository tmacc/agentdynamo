---
const faqs = [
  {
    q: "Is Dynamo production-ready?",
    a: "No — Dynamo is early alpha. Expect bugs, rough edges, and occasional breaking changes. We use it daily on real work, but it's not the right fit if you need a polished, stable tool today.",
  },
  {
    q: "Do I need accounts for every provider?",
    a: "You need at least one. Dynamo launches provider CLIs locally, so install the ones you want — `codex login` for OpenAI's Codex CLI, `claude auth login` for Claude — and Dynamo will use whichever are available.",
  },
  {
    q: "Why not just use the Codex or Claude CLI directly?",
    a: "Because one terminal buffer can't show you a coordinator and three child agents working on different worktrees at the same time. Dynamo gives you a roster, a board, fork-able threads, and an explicit review-and-apply step — all the things a CLI either can't do or makes painful.",
  },
  {
    q: "Are the desktop builds signed and notarized?",
    a: "Code signing and notarization are still being finalized. Unsigned builds may require extra approval from your operating system on first launch.",
  },
  {
    q: "Where does my code and conversation history live?",
    a: "Locally. Dynamo runs a Node.js server on your machine, talks to provider CLIs you've already installed, and stores session state under `~/.dynamo`. We don't host your code or proxy your provider traffic.",
  },
  {
    q: "Is Dynamo open source?",
    a: "Yes. The repo is on GitHub. We're not accepting broad external contributions yet, but bug reports and small focused PRs are welcome — see CONTRIBUTING.md before opening an issue or PR.",
  },
];
---

<section id="faq" class="section">
  <div class="section-inner">
    <header class="header">
      <p class="eyebrow">FAQ</p>
      <h2 class="headline">Questions worth asking before you download.</h2>
    </header>

    <div class="list">
      {faqs.map((item) => (
        <details class="item">
          <summary class="summary">
            <span>{item.q}</span>
            <span class="chev" aria-hidden="true">+</span>
          </summary>
          <div class="answer">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    padding: var(--section-pad-y) var(--gutter);
    border-top: 1px solid var(--border);
  }

  .section-inner {
    max-width: 820px;
    margin: 0 auto;
  }

  .header {
    margin-bottom: clamp(2rem, 4vw, 3rem);
    text-align: center;
  }

  .eyebrow {
    font-size: var(--eyebrow-size);
    letter-spacing: var(--eyebrow-tracking);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .headline {
    font-size: clamp(1.75rem, 3.5vw, 2.4rem);
    letter-spacing: -0.03em;
    color: var(--fg);
  }

  .list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  .item {
    border-bottom: 1px solid var(--border);
  }

  .summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.4rem 0;
    font-size: 1.025rem;
    font-weight: 500;
    color: var(--fg);
    transition: color 0.2s ease;
  }

  .summary::-webkit-details-marker {
    display: none;
  }

  .summary:hover {
    color: var(--fg);
  }

  .chev {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    color: var(--fg-faint);
    font-size: 1.2rem;
    line-height: 1;
    transition: transform 0.25s ease, color 0.25s ease;
  }

  .item[open] .chev {
    transform: rotate(45deg);
    color: var(--accent);
  }

  .answer {
    padding-bottom: 1.4rem;
    color: var(--fg-muted);
    font-size: 0.97rem;
    max-width: 680px;
  }

  .answer :global(p) {
    margin: 0;
  }
</style>
