---
---

<section class="cta">
  <div class="cta-inner">
    <h2 class="headline">Stop juggling agents. Start coordinating them.</h2>
    <p class="sub">
      Dynamo is free and open source. macOS, Windows, Linux.
    </p>
    <div class="row">
      <a href="/download" class="primary">Download Dynamo</a>
      <a
        href="https://github.com/tmacc/agentdynamo"
        target="_blank"
        rel="noopener noreferrer"
        class="secondary"
      >
        View on GitHub <span aria-hidden="true">&#8599;</span>
      </a>
      <a
        href="https://discord.gg/jn4EGJjrvv"
        target="_blank"
        rel="noopener noreferrer"
        class="secondary"
      >
        Join Discord <span aria-hidden="true">&#8599;</span>
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    padding: clamp(5rem, 10vw, 9rem) var(--gutter);
    text-align: center;
    border-top: 1px solid var(--border);
    overflow: hidden;
  }

  .cta::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center bottom, var(--accent-soft) 0%, transparent 60%);
    opacity: 0.55;
    pointer-events: none;
    z-index: -1;
  }

  .cta-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .headline {
    font-size: clamp(2rem, 5vw, 3.25rem);
    letter-spacing: -0.035em;
    margin-bottom: 1.1rem;
    color: var(--fg);
  }

  .sub {
    color: var(--fg-muted);
    margin-bottom: 2rem;
    font-size: 1.05rem;
  }

  .row {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
  }

  .primary {
    background: var(--fg);
    color: var(--bg);
    padding: 0.85rem 1.75rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: 0.95rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 32px rgba(255, 255, 255, 0.12);
  }

  .secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.85rem 1.5rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--bg-raised);
    color: var(--fg-muted);
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .secondary:hover {
    color: var(--fg);
    border-color: var(--border-strong);
    background: var(--bg-elevated);
  }
</style>
