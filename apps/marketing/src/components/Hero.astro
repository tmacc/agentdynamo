        <span id="download-label">Download now</span>
      </a>

      <a href="/download" class="ghost-link">All platforms &rarr;</a>
    </div>

    <p class="hero-meta">
      Free · Open source · macOS, Windows, Linux
    </p>
  </div>

  <div class="screenshot-wrap">
    <img src="/screenshot.jpeg" alt="Dynamo desktop app" class="screenshot" />
  </div>
</section>

<script>
  import { fetchLatestRelease, RELEASES_URL, type ReleaseAsset } from "../lib/releases";

  type Platform = { os: "mac" | "win" | "linux"; label: string; arch?: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) {
      return {
        os: "mac",
        label: "Download for macOS",
        arch: "arm64",
      };
    }
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  function pickAsset(assets: ReleaseAsset[], platform: Platform): string | null {
    if (platform.os === "win") {
      return (
        assets.find((a) => a.name.endsWith("-x64.exe"))
          ?.browser_download_url ?? null
      );
    }
    if (platform.os === "mac") {
      const preferred = assets.find((a) =>
        a.name.endsWith(`-${platform.arch}.dmg`),
      );
      const fallback = assets.find((a) => a.name.endsWith(".dmg"));
      return (preferred ?? fallback)?.browser_download_url ?? null;
    }
    if (platform.os === "linux") {
      return (
        assets.find((a) => a.name.endsWith(".AppImage"))
          ?.browser_download_url ?? null
      );
    }
    return null;
  }

  async function init() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    if (!btn || !label) return;

    const platform = detectPlatform();
    if (!platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;

    try {
      const release = await fetchLatestRelease();
      const url = pickAsset(release.assets ?? [], platform);
      if (url) {
        btn.href = url;
        btn.removeAttribute("target");
        btn.removeAttribute("rel");
      }
    } catch {
      btn.href = RELEASES_URL;
    }
  }

  init();
</script>

<style>
  .hero {
    position: relative;
    padding: clamp(3rem, 7vw, 6rem) var(--gutter) clamp(3rem, 6vw, 5rem);
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    max-width: 1100px;
    height: 600px;
    background: radial-gradient(ellipse at center, var(--accent-soft) 0%, transparent 60%);
    pointer-events: none;
    opacity: 0.7;
    z-index: -1;
  }

  .hero-inner {
    max-width: var(--content-max-w);
    margin: 0 auto;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--bg-raised);
    color: var(--fg-muted);
    font-size: var(--eyebrow-size);
    letter-spacing: 0.04em;
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: fade-in 0.8s ease-out 0.05s forwards;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
  }

  .headline {
    font-weight: 500;
    font-size: clamp(2.2rem, 5.5vw, 4.25rem);
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 1.5rem;
    opacity: 0;
    animation: fade-in 0.9s ease-out 0.15s forwards;
  }

  .subhead {
    max-width: 640px;
    margin: 0 auto 2.25rem;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    color: var(--fg-muted);
    opacity: 0;
    animation: fade-in 0.9s ease-out 0.25s forwards;
  }

  .cta-row {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
    animation: fade-in 0.9s ease-out 0.35s forwards;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--fg);
    color: var(--bg);
    padding: 0.85rem 1.75rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: 0.95rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .hero-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 32px rgba(255, 255, 255, 0.12);
  }

  .hero-button:active {
    transform: scale(0.98);
  }

  .hero-button-icon {
    display: none;
    width: 1em;
    height: 1em;
    flex-shrink: 0;
  }

  :global([data-platform="mac"]) .hero-button-icon--apple {
    display: block;
  }

  :global([data-platform="win"]) .hero-button-icon--windows {
    display: block;
  }

  :global([data-platform="linux"]) .hero-button-icon--linux {
    display: block;
  }

  .ghost-link {
    color: var(--fg-muted);
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .ghost-link:hover {
    color: var(--fg);
  }

  .hero-meta {
    margin-top: 1.25rem;
    font-size: 0.8rem;
    color: var(--fg-faint);
    opacity: 0;
    animation: fade-in 0.9s ease-out 0.45s forwards;
  }

  .screenshot-wrap {
    margin: clamp(3rem, 6vw, 5rem) auto 0;
    width: min(95vw, 1280px);
    opacity: 0;
    transform: scale(0.98);
    animation: screenshot-in 1s ease-out 0.4s forwards;
    position: relative;
  }

  .screenshot-wrap::before {
    content: "";
    position: absolute;
    inset: -40px;
    background: radial-gradient(ellipse at center, var(--accent-soft) 0%, transparent 70%);
    z-index: -1;
    opacity: 0.6;
    filter: blur(40px);
  }

  .screenshot {
    width: 100%;
    display: block;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
    mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
  }

  @keyframes screenshot-in {
    from {
      opacity: 0;
      transform: scale(0.98);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (max-width: 720px) {
    .headline {
      letter-spacing: -0.03em;
    }

    .cta-row {
      flex-direction: column;
      gap: 0.85rem;
    }
  }
</style>
