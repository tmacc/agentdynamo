---
import Layout from "../layouts/Layout.astro";
import { RELEASES_URL } from "../lib/releases";

const platforms = [
  {
    name: "macOS",
    accent: "pink",
    downloads: [
      { label: "Apple Silicon", detail: "arm64", format: ".dmg", asset: "arm64.dmg" },
      { label: "Intel", detail: "x64", format: ".dmg", asset: "x64.dmg" },
    ],
  },
  {
    name: "Windows",
    accent: "blue",
    downloads: [{ label: "Windows 10, 11", detail: "x64", format: ".exe", asset: "x64.exe" }],
  },
  {
    name: "Linux",
    accent: "green",
    downloads: [{ label: "x86_64", detail: "AppImage", format: "AppImage", asset: "x86_64.AppImage" }],
  },
];
---

<Layout
  title="Download Dynamo"
  description="Download early alpha Dynamo builds for macOS, Windows, and Linux."
>
  <section class="download-hero">
    <p class="eyebrow">Download</p>
    <h1>Download Dynamo</h1>
    <p>
      Early alpha builds for macOS, Windows, and Linux. Install a supported
      provider CLI before starting.
    </p>
    <div class="release-row">
      <span id="version-label">Loading latest release&hellip;</span>
      <a
        id="changelog-link"
        class="changelog-link"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        style="display:none"
      >
        View changelog<span aria-hidden="true"> &#8599;</span>
      </a>
    </div>
  </section>

  <section class="download-layout" aria-label="Dynamo downloads">
    <div class="platforms" id="platforms">
      {platforms.map((platform) => (
        <section class={`platform-section platform-section-${platform.accent}`}>
          <div class="platform-header">
            <span class="platform-dot" aria-hidden="true"></span>
            <h2>{platform.name}</h2>
          </div>
          <div class="download-cards">
            {platform.downloads.map((download) => (
              <a class="download-card" data-asset={download.asset} href={RELEASES_URL}>
                <span class="card-main">
                  <span class="card-arch">{download.label}</span>
                  <span class="card-format">{download.format}</span>
                </span>
                <span class="card-detail">{download.detail}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <aside class="prerequisites" aria-labelledby="provider-setup">
      <p class="eyebrow">Provider setup</p>
      <h2 id="provider-setup">Bring your local agent CLIs.</h2>
      <p>
        Dynamo launches local provider tools. Authenticate at least one before
        opening your first project.
      </p>
      <ul>
        <li><strong>Codex:</strong> install Codex CLI and run <code>codex login</code>.</li>
        <li><strong>Claude:</strong> install Claude Code and run <code>claude auth login</code>.</li>
      </ul>
      <a
        href="https://github.com/tmacc/agentdynamo/releases"
        target="_blank"
        rel="noopener noreferrer"
      >
        Older releases<span aria-hidden="true"> &#8599;</span>
      </a>
    </aside>
  </section>
</Layout>

<script>
  import { fetchLatestRelease, RELEASES_URL } from "../lib/releases";

  async function init() {
    const versionLabel = document.getElementById("version-label");
    const cards = document.querySelectorAll<HTMLAnchorElement>(".download-card");

    try {
      const release = await fetchLatestRelease();

      if (versionLabel && release.tag_name) {
        versionLabel.textContent = `Latest (${release.tag_name})`;
      }

      const changelogLink = document.getElementById("changelog-link") as HTMLAnchorElement | null;
      if (changelogLink && release.html_url) {
        changelogLink.href = release.html_url;
        changelogLink.style.display = "";
      }

      cards.forEach((card) => {
        const suffix = card.dataset.asset;
        if (!suffix) return;

        const match = (release.assets ?? []).find((asset) => asset.name.endsWith(`-${suffix}`));
        card.href = match?.browser_download_url ?? RELEASES_URL;
      });
    } catch {
      if (versionLabel) {
        versionLabel.textContent = "Could not load release info.";
      }
      cards.forEach((card) => {
        card.href = RELEASES_URL;
      });
    }
  }

  init();
</script>

<style>
  .main {
    padding: 3.5rem 2rem 5rem;
  }

  .download-hero,
  .download-layout {
    width: min(100%, var(--max));
  }

  .download-hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 2.4rem;
  }

  .eyebrow {
    color: var(--green);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    letter-spacing: 0;
  }

  h1 {
    margin-top: 0.75rem;
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 0.98;
  }

  .download-hero p {
    max-width: 680px;
    margin-top: 1rem;
    color: var(--fg-muted);
    line-height: 1.65;
    font-size: 1.05rem;
  }

  .release-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.2rem;
    color: var(--fg-dim);
    font-size: 0.9rem;
  }

  .changelog-link,
  .prerequisites a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.28);
    text-underline-offset: 3px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .changelog-link:hover,
  .prerequisites a:hover {
    color: var(--blue);
    text-decoration-color: var(--blue);
  }

  .download-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    gap: 1rem;
    align-items: start;
  }

  .platforms {
    display: grid;
    gap: 0.85rem;
  }

  .platform-section,
  .prerequisites {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-panel);
  }

  .platform-section {
    padding: 1rem;
  }

  .platform-header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--border);
  }

  .platform-header h2 {
    font-size: 1.08rem;
    line-height: 1;
  }

  .platform-dot {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: var(--pink);
  }

  .platform-section-blue .platform-dot {
    background: var(--blue);
  }

  .platform-section-green .platform-dot {
    background: var(--green);
  }

  .download-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
    margin-top: 0.85rem;
  }

  .download-card {
    min-height: 92px;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.035);
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .download-card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }

  .download-card:active {
    transform: translateY(0);
  }

  .card-main {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .card-arch {
    font-weight: 700;
  }

  .card-format,
  .card-detail {
    color: var(--fg-dim);
    font-size: 0.84rem;
  }

  .prerequisites {
    position: sticky;
    top: 1rem;
    padding: 1.15rem;
  }

  .prerequisites h2 {
    margin-top: 0.65rem;
    font-size: 1.4rem;
    line-height: 1.1;
  }

  .prerequisites p,
  .prerequisites li {
    color: var(--fg-muted);
    line-height: 1.55;
  }

  .prerequisites p {
    margin-top: 0.85rem;
  }

  .prerequisites ul {
    display: grid;
    gap: 0.65rem;
    margin: 1rem 0 1.25rem;
    padding-left: 1.1rem;
  }

  code {
    color: var(--fg);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.1rem 0.3rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9em;
  }

  @media (max-width: 820px) {
    .download-layout {
      grid-template-columns: 1fr;
    }

    .prerequisites {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .main {
      padding: 2.5rem 1.25rem 4rem;
    }

    .download-cards {
      grid-template-columns: 1fr;
    }

    .download-card {
      min-height: auto;
    }
  }
</style>
