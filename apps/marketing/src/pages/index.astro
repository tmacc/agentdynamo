---
import Layout from "../layouts/Layout.astro";

const proofPoints = ["Visual orchestration", "Cross-provider teams", "Inspectable context", "Reviewable patches"];

const beliefs = [
  {
    title: "See the whole build",
    copy:
      "Threads, child agents, terminals, diffs, and project state live in one app surface instead of scattered chat logs.",
  },
  {
    title: "Route work to the right model",
    copy:
      "Use Codex, Claude, and other local harnesses where they fit best, without starting the build over.",
  },
  {
    title: "Make context inspectable",
    copy:
      "Prompts, instructions, tools, skills, design systems, setup, and provider health should be visible to the builder.",
  },
  {
    title: "Keep autonomy bounded",
    copy:
      "Parallel agents get isolated worktrees and reviewable patches. You decide what lands.",
  },
];

const workflow = [
  {
    step: "01",
    title: "Ask for a team",
    copy:
      "Give Dynamo the outcome. The coordinator can route bounded work to the right provider, model, and task shape.",
  },
  {
    step: "02",
    title: "Watch child agents work",
    copy:
      "Follow status, summaries, tool activity, terminals, and direct child follow-ups from one visual workspace.",
  },
  {
    step: "03",
    title: "Review and apply patches",
    copy:
      "Inspect the child diff before it touches your coordinator worktree. Apply only the work you decide should land.",
  },
];

const features = [
  {
    image: "/hero-agents.webp",
    alt: "Dynamo Agents drawer showing multiple child coding agents with status, summaries, and review controls.",
    eyebrow: "Agent orchestration",
    title: "Parallel work stays visible.",
    copy:
      "Dynamo treats agent teams like first-class collaborators with lifecycle state, child chats, summaries, and explicit controls.",
  },
  {
    image: "/feature-board.webp",
    alt: "Dynamo project board with linked implementation cards moving through planned, in-progress, review, and done columns.",
    eyebrow: "App-building flow",
    title: "Plans can become tracked work.",
    copy:
      "Use the board to carry ideas, proposed-plan tasks, active agent threads, and review states across a real build.",
  },
  {
    image: "/feature-project-intelligence.webp",
    alt: "Dynamo Project Intelligence screen showing provider health, agent instructions, tools, skills, worktree setup, and warnings.",
    eyebrow: "Context management",
    title: "Context is inspectable.",
    copy:
      "Prompts, provider settings, project instructions, MCP tools, skills, scripts, and setup are surfaced instead of hidden in scattered files.",
  },
];
---

<Layout
  title="Dynamo - Agent Orchestrator for Building Apps"
  description="Dynamo is the visual agent orchestrator for building apps with cross-provider coding agents, isolated worktrees, reviewable patches, and inspectable project context."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">The agent orchestrator for building apps</p>
      <h1>The visual command center for agent teams.</h1>
      <p class="hero-lede">
        Dynamo is a visual workspace for cross-provider agent teams, isolated worktrees,
        inspectable context, and reviewable patches. The builder stays in control.
      </p>

      <div class="hero-actions">
        <a id="download-btn" href="https://github.com/tmacc/agentdynamo/releases" class="button button-primary">
          <span id="download-label">Download Dynamo</span>
        </a>
        <a
          href="https://github.com/tmacc/agentdynamo"
          target="_blank"
          rel="noopener noreferrer"
          class="button button-secondary"
        >
          View on GitHub
          <span aria-hidden="true">&#8599;</span>
        </a>
      </div>

      <div class="proof-points" aria-label="Dynamo proof points">
        {proofPoints.map((item) => <span>{item}</span>)}
      </div>
    </div>

    <div class="hero-visual">
      <img
        src="/hero-agents.webp"
        alt="Dynamo workspace showing a coordinator thread, Agents drawer, child agent statuses, isolated worktrees, and review controls."
        width="1600"
        height="1000"
        loading="eager"
      />
    </div>
  </section>

  <section class="section section-tight" aria-labelledby="why-dynamo">
    <div class="section-heading">
      <p class="eyebrow">Why Dynamo</p>
      <h2 id="why-dynamo">Agentic builders need more than another chat box.</h2>
      <p>
        Serious app work is visual, long-running, and full of moving parts. Dynamo makes
        the orchestration layer visible so the builder stays in control.
      </p>
    </div>
    <div class="belief-grid">
      {beliefs.map((belief) => (
        <article class="belief-card">
          <h3>{belief.title}</h3>
          <p>{belief.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section workflow-section" aria-labelledby="workflow">
    <div class="section-heading">
      <p class="eyebrow">Workflow</p>
      <h2 id="workflow">From prompt to reviewed patch.</h2>
    </div>
    <div class="workflow">
      {workflow.map((item) => (
        <article class="workflow-step">
          <span>{item.step}</span>
          <h3>{item.title}</h3>
          <p>{item.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section feature-section" aria-labelledby="product-proof">
    <div class="section-heading">
      <p class="eyebrow">Product proof</p>
      <h2 id="product-proof">Purpose-built surfaces for real agent work.</h2>
    </div>
    <div class="feature-grid">
      {features.map((feature) => (
        <article class="feature-card">
          <img src={feature.image} alt={feature.alt} loading="lazy" width="1600" height="1000" />
          <div>
            <p class="feature-eyebrow">{feature.eyebrow}</p>
            <h3>{feature.title}</h3>
            <p>{feature.copy}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section alpha-section" aria-labelledby="alpha">
    <div>
      <p class="eyebrow">Early alpha</p>
      <h2 id="alpha">For builders comfortable with local coding-agent tools.</h2>
    </div>
    <div class="alpha-copy">
      <p>
        Dynamo is early alpha software for developers who already work with local
        agent CLIs and want a visible way to orchestrate real app-building work.
      </p>
      <ul>
        <li><strong>Codex:</strong> install Codex CLI and run <code>codex login</code>.</li>
        <li><strong>Claude:</strong> install Claude Code and run <code>claude auth login</code>.</li>
      </ul>
    </div>
  </section>

  <section class="final-cta" aria-labelledby="download">
    <p class="eyebrow">Build with agent teams</p>
    <h2 id="download">Build with agents you can actually see, steer, and review.</h2>
    <div class="hero-actions">
      <a href="https://github.com/tmacc/agentdynamo/releases" class="button button-primary">
        Download Dynamo
      </a>
      <a href="/download" class="button button-secondary">Other platforms</a>
    </div>
  </section>
</Layout>

<script>
  import { fetchLatestRelease, RELEASES_URL, type ReleaseAsset } from "../lib/releases";

  type Platform = { os: "mac" | "win" | "linux"; label: string; arch?: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) return { os: "mac", label: "Download for macOS", arch: "arm64" };
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  function pickAsset(assets: ReleaseAsset[], platform: Platform): string | null {
    if (platform.os === "win") {
      return assets.find((asset) => asset.name.endsWith("-x64.exe"))?.browser_download_url ?? null;
    }
    if (platform.os === "mac") {
      const preferred = assets.find((asset) => asset.name.endsWith(`-${platform.arch}.dmg`));
      const fallback = assets.find((asset) => asset.name.endsWith(".dmg"));
      return (preferred ?? fallback)?.browser_download_url ?? null;
    }
    if (platform.os === "linux") {
      return assets.find((asset) => asset.name.endsWith(".AppImage"))?.browser_download_url ?? null;
    }
    return null;
  }

  async function init() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    if (!btn || !label) return;

    const platform = detectPlatform();
    if (!platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;

    try {
      const release = await fetchLatestRelease();
      const url = pickAsset(release.assets ?? [], platform);
      if (url) btn.href = url;
    } catch {
      btn.href = RELEASES_URL;
    }
  }

  init();
</script>

<style>
  .main {
    gap: 0;
  }

  .hero {
    width: min(100%, calc(var(--max) + 144px));
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.32fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
    padding: clamp(2.5rem, 5vw, 4rem) 2rem clamp(3.5rem, 6vw, 5.5rem);
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .eyebrow,
  .feature-eyebrow {
    color: var(--green);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    letter-spacing: 0;
  }

  h1 {
    margin-top: 0.95rem;
    font-size: clamp(2.25rem, 3.4vw, 3.4rem);
    line-height: 1.04;
    letter-spacing: -0.018em;
    max-width: 18ch;
  }

  .hero-lede,
  .section-heading p,
  .alpha-copy p {
    color: var(--fg-muted);
    line-height: 1.6;
  }

  .hero-lede {
    margin-top: 1.1rem;
    max-width: 36rem;
    font-size: clamp(1rem, 1.1vw, 1.08rem);
    color: #d7d9e1;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.5rem;
  }

  .button {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    border-radius: 999px;
    padding: 0.72rem 1.1rem;
    font-size: 0.92rem;
    font-weight: 700;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button:active {
    transform: translateY(0);
  }

  .button-primary {
    background: var(--fg);
    color: #09090b;
  }

  .button-secondary {
    border: 1px solid var(--border-strong);
    background: rgba(255, 255, 255, 0.04);
    color: var(--fg);
  }

  .proof-points {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.4rem;
  }

  .proof-points span {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.7rem;
    color: var(--fg-muted);
    font-size: 0.8rem;
    background: rgba(255, 255, 255, 0.035);
  }

  .hero-visual {
    position: relative;
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    overflow: hidden;
    background: #0e0e12;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 30px 120px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(255, 255, 255, 0.02);
    width: 100%;
    justify-self: stretch;
  }

  .hero-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.05) 0%,
      transparent 22%,
      transparent 88%,
      rgba(0, 0, 0, 0.18) 100%
    );
  }

  .hero-visual img {
    display: block;
    width: 100%;
    height: auto;
  }

  .section {
    width: min(100%, calc(var(--max) + 64px));
    padding: 5rem 2rem;
  }

  .section-tight {
    padding-top: 1.5rem;
  }

  .section-heading {
    max-width: 760px;
  }

  .section-heading h2,
  .alpha-section h2,
  .final-cta h2 {
    margin-top: 0.65rem;
    font-size: clamp(2rem, 3.5vw, 3.25rem);
    line-height: 1.04;
  }

  .section-heading p {
    margin-top: 1rem;
    max-width: 650px;
  }

  .belief-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 1.6rem;
  }

  .belief-card,
  .workflow-step,
  .feature-card,
  .alpha-section,
  .final-cta {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-panel);
  }

  .belief-card {
    min-height: 184px;
    padding: 1.15rem;
  }

  .belief-card h3,
  .workflow-step h3,
  .feature-card h3 {
    font-size: 1.02rem;
    line-height: 1.2;
  }

  .belief-card p,
  .workflow-step p,
  .feature-card p {
    margin-top: 0.7rem;
    color: var(--fg-muted);
    line-height: 1.55;
    font-size: 0.9rem;
  }

  .workflow-section {
    padding-top: 3.5rem;
  }

  .workflow {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 1.6rem;
  }

  .workflow-step {
    padding: 1.2rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.03));
  }

  .workflow-step span {
    display: block;
    margin-bottom: 1rem;
    color: var(--blue);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.8rem;
  }

  .feature-card {
    display: grid;
    grid-template-columns: minmax(0, 1.42fr) minmax(280px, 0.58fr);
    align-items: stretch;
    overflow: hidden;
  }

  .feature-card:nth-child(even) {
    grid-template-columns: minmax(280px, 0.58fr) minmax(0, 1.42fr);
  }

  .feature-card:nth-child(even) img {
    order: 2;
    border-left: 1px solid var(--border);
    border-right: 0;
  }

  .feature-card:nth-child(even) div {
    order: 1;
  }

  .feature-card img {
    width: 100%;
    height: 100%;
    min-height: 360px;
    object-fit: cover;
    border-right: 1px solid var(--border);
  }

  .feature-card div {
    padding: clamp(1.35rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .feature-card h3 {
    margin-top: 0.65rem;
    font-size: clamp(1.45rem, 2.7vw, 2.35rem);
  }

  .feature-card p:not(.feature-eyebrow) {
    font-size: 1rem;
  }

  .alpha-section {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 2.25rem;
    padding-top: clamp(2rem, 5vw, 3.5rem);
    padding-bottom: clamp(2rem, 5vw, 3.5rem);
    background:
      linear-gradient(135deg, rgba(242, 29, 114, 0.13), transparent 46%),
      var(--bg-panel);
  }

  .alpha-copy ul {
    display: grid;
    gap: 0.65rem;
    margin-top: 1.2rem;
    padding-left: 1.1rem;
    color: var(--fg-muted);
    line-height: 1.5;
  }

  code {
    color: var(--fg);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.1rem 0.3rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9em;
  }

  .final-cta {
    width: min(100% - 4rem, var(--max));
    margin: 0 auto 3rem;
    padding: clamp(2rem, 5vw, 4rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    background:
      radial-gradient(circle at 25% 0%, rgba(66, 211, 146, 0.16), transparent 22rem),
      radial-gradient(circle at 75% 12%, rgba(90, 184, 255, 0.14), transparent 24rem),
      var(--bg-panel);
  }

  .final-cta h2 {
    max-width: 760px;
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 2.5rem;
    }

    h1 {
      max-width: 18ch;
    }

    .hero-visual {
      max-width: 720px;
    }

    .belief-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .workflow,
    .alpha-section,
    .feature-card,
    .feature-card:nth-child(even) {
      grid-template-columns: 1fr;
    }

    .feature-card img,
    .feature-card:nth-child(even) img {
      order: 0;
      border-right: 0;
      border-left: 0;
      border-bottom: 1px solid var(--border);
    }

    .feature-card:nth-child(even) div {
      order: 0;
    }
  }

  @media (max-width: 640px) {
    .hero,
    .section {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .hero {
      padding-top: 1.75rem;
      padding-bottom: 3rem;
    }

    h1 {
      font-size: clamp(2rem, 9.5vw, 2.6rem);
      max-width: 22ch;
    }

    .hero-actions,
    .button {
      width: 100%;
    }

    .button {
      min-height: 46px;
    }

    .belief-grid,
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .belief-card {
      min-height: auto;
    }

    .section {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }

    .final-cta {
      width: calc(100% - 2.5rem);
    }
  }
</style>
