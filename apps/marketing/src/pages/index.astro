---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ProvidersStrip from "../components/ProvidersStrip.astro";
import BeliefSection from "../components/BeliefSection.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import Quickstart from "../components/Quickstart.astro";
import Faq from "../components/Faq.astro";
import CtaFooter from "../components/CtaFooter.astro";
---

<Layout>
  <Hero />
  <ProvidersStrip />

  <div id="beliefs">
    <BeliefSection
      eyebrow="Belief · Why a GUI"
      headline="Agents deserve more than one terminal buffer."
    >
      <p>
        A coding agent in a terminal is fundamentally a <strong>single-threaded
        chat</strong>. One buffer, one provider, one working directory, and a
        scrollback you have to grep to remember what happened.
      </p>
      <p>
        Dynamo is built around the truth that agentic work is parallel.
        Coordinator threads spawn children, children claim worktrees, plans get
        revised, diffs queue for review. None of that fits in a TTY.
      </p>
      <p>
        The desktop UI gives you a roster of agents, a board of plans, fork-able
        threads, side-by-side diffs, and an embedded terminal for the moments
        when you actually want one — not as the only surface area you get.
      </p>

      <div slot="media" class="cli-vs-gui" aria-hidden="true">
        <div class="cli-pane">
          <div class="pane-label">A CLI</div>
          <pre class="cli-stream"><code>$ codex
&gt; refactor the auth module
running...
████░░░░░░ 40%
&gt; _</code></pre>
          <div class="pane-meta">1 thread · 1 provider · 1 cwd</div>
        </div>
        <div class="gui-pane">
          <div class="pane-label">Dynamo</div>
          <div class="gui-rows">
            <div class="gui-row">
              <span class="dot dot-coord"></span>
              <span class="row-label">coordinator</span>
              <span class="row-tag">claude</span>
            </div>
            <div class="gui-row gui-row-child">
              <span class="dot dot-active"></span>
              <span class="row-label">refactor auth</span>
              <span class="row-tag">codex · gpt-5</span>
            </div>
            <div class="gui-row gui-row-child">
              <span class="dot dot-active"></span>
              <span class="row-label">add tests</span>
              <span class="row-tag">claude · sonnet</span>
            </div>
            <div class="gui-row gui-row-child">
              <span class="dot dot-review"></span>
              <span class="row-label">migrate db</span>
              <span class="row-tag">review</span>
            </div>
          </div>
          <div class="pane-meta">4 threads · 2 providers · isolated worktrees</div>
        </div>
      </div>
    </BeliefSection>

    <BeliefSection
      eyebrow="Belief · Why multi-provider"
      headline="No single model is best at everything you ship."
      reverse
    >
      <p>
        Codex is great at certain refactors. Claude is great at long context
        and explaining trade-offs. Cursor is great inside an existing repo
        graph. Locking your whole flow to one of them is a tax you pay
        forever.
      </p>
      <p>
        Dynamo treats providers as <strong>interchangeable workers</strong>.
        Every session declares a provider and a model. The team coordinator
        spawns child agents and picks the right provider per task — and you
        can hand a thread off mid-conversation when it stops being the right
        tool.
      </p>
      <p>
        The result is the kind of routing you&apos;d build by hand if you had
        the time, made native to the surface where you actually work.
      </p>

      <div slot="media" class="routing" aria-hidden="true">
        <div class="route-task">a feature request</div>
        <div class="route-pipe"></div>
        <div class="route-coord">
          <span class="route-coord-dot"></span>
          coordinator
        </div>
        <div class="route-fan">
          <span class="route-fan-line"></span>
          <span class="route-fan-line"></span>
          <span class="route-fan-line"></span>
        </div>
        <div class="route-targets">
          <div class="route-target"><span class="rt-name">codex</span><span class="rt-task">refactor</span></div>
          <div class="route-target"><span class="rt-name">claude</span><span class="rt-task">tests</span></div>
          <div class="route-target"><span class="rt-name">cursor</span><span class="rt-task">migrate</span></div>
        </div>
      </div>
    </BeliefSection>
  </div>

  <FeatureGrid />

  <section class="marquee">
    <div class="marquee-inner">
      <p class="eyebrow">In the app</p>
      <h2 class="headline">A surface that respects the work.</h2>
      <p class="lede">
        The full app — coordinator threads on the left, plan and agents
        drawer docked on the right, embedded terminal at the bottom for the
        moments you need one.
      </p>
      <div class="marquee-frame">
        <img src="/screenshot.jpeg" alt="Dynamo desktop app showing coordinator and child agents" />
      </div>
    </div>
  </section>

  <Quickstart />
  <Faq />
  <CtaFooter />
</Layout>

<style>
  /* ── CLI vs GUI illustration ── */

  .cli-vs-gui {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
    width: 100%;
  }

  .cli-pane,
  .gui-pane {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem;
    min-height: 240px;
    display: flex;
    flex-direction: column;
  }

  .cli-pane {
    background: #07070a;
  }

  .pane-label {
    font-size: 0.7rem;
    letter-spacing: var(--eyebrow-tracking);
    text-transform: uppercase;
    color: var(--fg-faint);
    margin-bottom: 0.85rem;
  }

  .cli-stream {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 0.78rem;
    color: var(--fg-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .cli-stream code {
    font-family: inherit;
  }

  .pane-meta {
    margin-top: 0.85rem;
    font-size: 0.7rem;
    color: var(--fg-faint);
    border-top: 1px dashed var(--border);
    padding-top: 0.6rem;
  }

  .gui-rows {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .gui-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 0.6rem;
    border-radius: var(--radius-sm);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    font-size: 0.82rem;
  }

  .gui-row-child {
    margin-left: 1rem;
    background: transparent;
  }

  .row-label {
    flex: 1;
    color: var(--fg);
  }

  .row-tag {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 0.7rem;
    color: var(--fg-faint);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-coord {
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
  }

  .dot-active {
    background: #22c55e;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.6);
  }

  .dot-review {
    background: #eab308;
  }

  /* ── Multi-provider routing illustration ── */

  .routing {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-raised);
  }

  .route-task {
    padding: 0.55rem 1rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  .route-pipe {
    width: 1px;
    height: 28px;
    background: linear-gradient(to bottom, transparent, var(--border-strong));
  }

  .route-fan {
    width: 100%;
    height: 32px;
    position: relative;
    display: flex;
    justify-content: space-between;
    padding: 0 16%;
  }

  .route-fan-line {
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, var(--border-strong), transparent);
  }

  .route-coord {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--accent);
    background: var(--accent-soft);
    color: var(--fg);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .route-coord-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
  }

  .route-targets {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.6rem;
    width: 100%;
  }

  .route-target {
    padding: 0.6rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-elevated);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-align: left;
  }

  .rt-name {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .rt-task {
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  /* ── Marquee screenshot section ── */

  .marquee {
    padding: var(--section-pad-y) var(--gutter);
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .marquee-inner {
    max-width: var(--section-max-w);
    margin: 0 auto;
  }

  .marquee .eyebrow {
    font-size: var(--eyebrow-size);
    letter-spacing: var(--eyebrow-tracking);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .marquee .headline {
    font-size: clamp(1.75rem, 3.5vw, 2.6rem);
    letter-spacing: -0.03em;
    margin-bottom: 1.1rem;
    color: var(--fg);
  }

  .marquee .lede {
    color: var(--fg-muted);
    font-size: 1.05rem;
    max-width: 640px;
    margin: 0 auto clamp(2.5rem, 5vw, 4rem);
  }

  .marquee-frame {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-raised);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
    position: relative;
  }

  .marquee-frame::before {
    content: "";
    position: absolute;
    inset: -60px;
    background: radial-gradient(ellipse at center, var(--accent-soft) 0%, transparent 70%);
    z-index: -1;
    opacity: 0.4;
    filter: blur(40px);
  }

  .marquee-frame img {
    width: 100%;
    display: block;
  }

  @media (max-width: 720px) {
    .cli-vs-gui {
      grid-template-columns: 1fr;
    }
  }
</style>
